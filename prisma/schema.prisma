generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model achievements {
  id_achievement    BigInt              @id @default(autoincrement())
  title             String?             @db.VarChar(100)
  description       String?             @db.VarChar(100)
  difficulty        difficulty?
  icon_url          String?
  created_at        DateTime?           @db.Timestamp(6)
  users_achievement users_achievement[]
}

model templates {
  id_template BigInt    @id @default(autoincrement())
  title       String    @db.VarChar(100)
  description String    @db.VarChar(100)
  category    category
  due_days    Int
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
  priority    priority?
}

model todos {
  id_todo     BigInt    @id @default(autoincrement())
  id_user     BigInt?
  title       String    @db.VarChar(100)
  description String?   @db.VarChar(100)
  priority    priority
  category    category
  status      status?   @default(ToDo)
  created_at  DateTime? @db.Timestamp(6)
  done_at     DateTime? @db.Timestamp(6)
  due_date    DateTime? @db.Timestamp(6)
  users       users?    @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id_user           BigInt              @id @default(autoincrement())
  profilePhotoUrl   String?             @default("https://wallpapersok.com/images/thumbnail/cute-cat-eyes-profile-picture-uq3edzmg1guze2hh.webp") @map("profile_photo")
  displayName       String              @map("display_name") @db.VarChar(50)
  username          String              @unique @map("username") @db.VarChar(50)
  pronouns          String?             @map("pronouns") @db.VarChar(20)
  bio               String?             @map("bio") @db.VarChar(100)
  email             String?             @map("email") @db.VarChar(40)
  instagram         String?             @map("instagram") @db.VarChar(40)
  linkedin          String?             @map("linkedin") @db.VarChar(40)
  created_at        DateTime?           @db.Timestamp(6)
  updated_at        DateTime?           @db.Timestamp(6)
  todos             todos[]
  users_achievement users_achievement[]
}

model users_achievement {
  id             BigInt        @id @default(autoincrement())
  id_user        BigInt?
  id_achievement BigInt?
  completed_at   DateTime?     @db.Timestamp(6)
  achievements   achievements? @relation(fields: [id_achievement], references: [id_achievement], onDelete: NoAction, onUpdate: NoAction)
  users          users?        @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
}

enum category {
  College
  Productivity
  Work
  Personal
}

enum difficulty {
  Hard
  Medium
  Easy
}

enum priority {
  High
  Medium
  Low
}

enum status {
  ToDo
  In_Progress @map("In Progress")
  Done
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}
